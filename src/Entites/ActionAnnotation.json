{
  "name": "ActionAnnotation",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Reference to VideoTask (analyst task)"
    },
    "video_id": {
      "type": "string",
      "description": "Reference to Video"
    },
    "start_time": {
      "type": "number",
      "description": "Action start timestamp"
    },
    "end_time": {
      "type": "number",
      "description": "Action end timestamp"
    },
    "action_category": {
      "type": "string",
      "enum": [
        "pass",
        "shot",
        "dribble",
        "defensive_action"
      ],
      "description": "Primary action category"
    },
    "pitch_start_x": {
      "type": "number",
      "description": "Pitch X coordinate (0-100)"
    },
    "pitch_start_y": {
      "type": "number",
      "description": "Pitch Y coordinate (0-100)"
    },
    "pitch_end_x": {
      "type": "number",
      "description": "End X coordinate for passes/dribbles"
    },
    "pitch_end_y": {
      "type": "number",
      "description": "End Y coordinate for passes/dribbles"
    },
    "outcome": {
      "type": "string",
      "enum": [
        "successful",
        "unsuccessful",
        "partially_successful"
      ]
    },
    "context": {
      "type": "string",
      "enum": [
        "open_play",
        "set_piece"
      ]
    },
    "pass_length": {
      "type": "string",
      "enum": [
        "short",
        "medium",
        "long"
      ]
    },
    "pass_direction": {
      "type": "string",
      "enum": [
        "forward",
        "lateral",
        "backward"
      ]
    },
    "shot_result": {
      "type": "string",
      "enum": [
        "goal",
        "on_target",
        "off_target",
        "blocked"
      ]
    },
    "goal_target_x": {
      "type": "number",
      "description": "Goal target X (0-100)"
    },
    "goal_target_y": {
      "type": "number",
      "description": "Goal target Y (0-100)"
    },
    "body_part": {
      "type": "string",
      "enum": [
        "left_foot",
        "right_foot",
        "head",
        "other"
      ]
    },
    "defensive_pressure": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "description": "Number of nearby defenders (3 means 3+)"
    },
    "opponents_bypassed": {
      "type": "number",
      "enum": [
        0,
        1,
        2,
        3
      ],
      "description": "For dribbles"
    },
    "defensive_action_type": {
      "type": "string",
      "enum": [
        "tackle_attempt",
        "interception",
        "pressure_close_down",
        "block",
        "clearance",
        "defensive_duel",
        "ball_recovery",
        "tracking_cover_run"
      ]
    },
    "defensive_consequence": {
      "type": "string",
      "enum": [
        "ball_recovered",
        "ball_with_opponent",
        "foul_committed",
        "play_stopped"
      ]
    },
    "note": {
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "video_id",
    "start_time",
    "end_time",
    "action_category",
    "pitch_start_x",
    "pitch_start_y",
    "outcome"
  ]
}