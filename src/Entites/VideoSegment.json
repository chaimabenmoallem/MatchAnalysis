{
  "name": "VideoSegment",
  "type": "object",
  "properties": {
    "task_id": {
      "type": "string",
      "description": "Reference to VideoTask"
    },
    "video_id": {
      "type": "string",
      "description": "Reference to Video"
    },
    "start_time": {
      "type": "number",
      "description": "Segment start time (relative to match start)"
    },
    "end_time": {
      "type": "number",
      "description": "Segment end time (relative to match start)"
    },
    "segment_type": {
      "type": "string",
      "enum": [
        "player_involvement",
        "pre_match",
        "half_time",
        "other"
      ],
      "default": "player_involvement"
    },
    "zone": {
      "type": "string",
      "enum": [
        "defending",
        "midfield",
        "attacking",
        "transition"
      ]
    },
    "player_visible": {
      "type": "boolean",
      "default": true
    },
    "notes": {
      "type": "string"
    },
    "order_index": {
      "type": "number"
    }
  },
  "required": [
    "task_id",
    "video_id",
    "start_time",
    "end_time"
  ]
}